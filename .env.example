# Copy to .env and fill in real values for local production-mode testing.
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
# Leave blank to use SQLite, or set e.g. postgres://user:pass@host:5432/dbname
DATABASE_URL=
# Auto-provision the fixed admin account on first deploy.
DJANGO_ADMIN_USERNAME=admin
DJANGO_ADMIN_PASSWORD=change-me
DJANGO_ADMIN_EMAIL=admin@example.com
# Set to "true" to overwrite the admin password on the next deploy.
DJANGO_ADMIN_RESET_PASSWORD=false
